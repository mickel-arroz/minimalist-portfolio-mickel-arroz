---
import CloseIcon from '@/icons/general/close-icon.astro';

interface Props {
  id: string;
  label?: string;
}

const { id, label } = Astro.props;
---

<dialog class="modal" id={id} aria-label={label}>
  <div class="modal__box">
    <div class="modal__actions">
      <slot name="actions" />
      <button
        type="button"
        class="modal__close"
        data-modal-close
        title="Cerrar"
        aria-label="Cerrar"
      >
        <CloseIcon />
      </button>
    </div>
    <div class="modal__content">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .modal {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    overflow: hidden;
    color: var(--colorSummary);

    opacity: 0;
    transition:
      opacity 0.5s ease,
      overlay 0.5s ease allow-discrete,
      display 0.5s ease allow-discrete;
  }

  .modal[open] {
    display: flex;
    opacity: 1;
  }

  @starting-style {
    .modal[open] {
      opacity: 0;
    }
  }

  .modal::backdrop {
    background: rgba(20, 20, 20, 0);
    transition: background 0.5s ease;
  }

  .modal[open]::backdrop {
    background: rgba(20, 20, 20, 0.6);
    backdrop-filter: blur(2px);
  }

  @starting-style {
    .modal[open]::backdrop {
      background: rgba(20, 20, 20, 0);
    }
  }

  .modal__box {
    position: relative;
    width: min(860px, 92vw);
    max-height: 85vh;
    overflow: hidden;
    background-color: var(--bgBody);
    border: var(--borderCard);
    border-radius: var(--borderRadius);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.25);
    padding: 1.5rem;

    transform: translateY(14px) scale(0.98);
    transition: transform 0.5s ease;
  }

  .modal__box.is-scrollable {
    overflow-y: auto;
  }

  .modal[open] .modal__box {
    transform: none;
  }

  @starting-style {
    .modal[open] .modal__box {
      transform: translateY(14px) scale(0.98);
    }
  }

  .modal__actions {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 2;
  }

  .modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem;
    background-color: var(--bgSpanTag);
    color: var(--colorButton);
    border: var(--borderButton);
    border-radius: var(--borderRadius);
    cursor: pointer;
  }

  .modal__close:hover {
    background: var(--bgButtonHover);
    border-color: var(--colorBorderButtonHover);
    color: var(--colorButtonHover);
  }

  .modal__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-right: 1.75rem;
  }
</style>

<style is:global>
  [data-modal-open] {
    cursor: pointer;
  }

  .modal__details {
    color: var(--colorSummary);
    font-size: var(--sizeSummary);
    line-height: var(--sizeLineHeightTexto);
    border-top: var(--borderCard);
    padding-top: 1rem;
  }

  .modal__details > *:first-child {
    margin-top: 0;
  }

  .modal__details > *:last-child {
    margin-bottom: 0;
  }

  .modal__details img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1rem auto;
    border-radius: var(--borderRadius);
    border: var(--borderCard);
  }

  .modal__details figure {
    margin: 1rem 0;
  }

  .modal__details figcaption {
    font-size: var(--sizeSpanTagXL);
    color: var(--colorSpanTag);
    text-align: center;
    margin-top: 0.35rem;
  }

  .modal__details h1,
  .modal__details h2,
  .modal__details h3,
  .modal__details h4,
  .modal__details h5,
  .modal__details h6 {
    display: block;
    width: auto;
    color: var(--colorSubTitle);
    font-weight: 600;
    border: none;
    padding: 0;
    background: transparent;
    margin: 1.1rem 0 0.5rem;
    line-height: 1.3;
  }

  .modal__details h3 {
    font-size: var(--sizeTitleElement);
  }

  .modal__details h4 {
    font-size: 1rem;
  }

  .modal__details p {
    color: var(--colorSummary);
    margin: 0 0 0.75rem;
    padding-inline: 0;
  }

  .modal__details ul,
  .modal__details ol {
    color: var(--colorSummary);
    margin: 0 0 0.75rem;
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    list-style: none;
  }

  .modal__details li {
    color: var(--colorSummary);
    line-height: 1.4;
  }

  .modal__details ul li::before {
    content: '-  ';
  }

  .modal__details ol {
    counter-reset: modal-item;
  }

  .modal__details ol li {
    counter-increment: modal-item;
  }

  .modal__details ol li::before {
    content: counter(modal-item) '. ';
  }

  .modal__details a {
    color: var(--colorSkill);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .modal__details a:hover {
    color: var(--colorLinkHover);
  }

  .modal__details strong,
  .modal__details b {
    color: var(--colorSubTitle);
    font-weight: 600;
  }

  .modal__details blockquote {
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    border-left: 3px solid var(--colorSkill);
    background-color: var(--bgSpanTag);
    border-radius: var(--borderRadius);
  }

  .modal__details code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background-color: var(--bgSpanTag);
    padding: 0.1rem 0.35rem;
    border-radius: var(--borderRadius);
    font-size: 0.85em;
  }

  @media print {
    .modal {
      display: none !important;
    }
  }
</style>

<script>
  const lockScroll = (lock: boolean) => {
    document.body.style.overflow = lock ? 'hidden' : '';
  };

  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;

    const opener = target.closest('[data-modal-open]');
    if (opener) {
      event.preventDefault();
      const id = opener.getAttribute('data-modal-open');
      const dialog = id
        ? (document.getElementById(id) as HTMLDialogElement | null)
        : null;
      if (dialog && typeof dialog.showModal === 'function') {
        dialog.showModal();
        lockScroll(true);
        const box = dialog.querySelector<HTMLElement>('.modal__box');
        if (box) {
          box.classList.remove('is-scrollable');
          const enable = () => box.classList.add('is-scrollable');
          const onEnd = (e: TransitionEvent) => {
            if (e.propertyName === 'transform') {
              enable();
              box.removeEventListener('transitionend', onEnd);
            }
          };
          box.addEventListener('transitionend', onEnd);
          window.setTimeout(enable, 700);
        }
      }
      return;
    }

    const closer = target.closest('[data-modal-close]');
    if (closer) {
      const dialog = closer.closest('dialog') as HTMLDialogElement | null;
      dialog?.close();
      return;
    }

    if (
      target instanceof HTMLDialogElement &&
      target.classList.contains('modal')
    ) {
      target.close();
    }
  });

  document.addEventListener(
    'close',
    (event) => {
      const dialog = event.target as HTMLDialogElement;
      if (dialog?.classList?.contains('modal')) {
        lockScroll(false);
        const box = dialog.querySelector<HTMLElement>('.modal__box');
        if (box) box.classList.remove('is-scrollable');
      }
    },
    true
  );
</script>
